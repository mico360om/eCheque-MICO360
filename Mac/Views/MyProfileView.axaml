<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="eCheque.MICO360.Mac.Views.MyProfileView">
    <ScrollViewer>
        <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Stretch">

            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="My Profile" Classes="cardTitle"/>
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Username" Classes="label"/>
                            <TextBox Text="{Binding Username}" IsReadOnly="True" Background="#F8F8F8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Role" Classes="label"/>
                            <TextBox Text="{Binding Role}" IsReadOnly="True" Background="#F8F8F8"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Full Name" Classes="label"/>
                        <TextBox Text="{Binding FullName}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email" Classes="label"/>
                        <TextBox Text="{Binding Email}"/>
                    </StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding ProfileStatus}" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#2E7D32" FontSize="12"/>
                        <Button Content="Save Profile" Classes="primary" DockPanel.Dock="Right" HorizontalAlignment="Right" Command="{Binding SaveProfileCommand}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel>
                    <TextBlock Text="Change Password" Classes="cardTitle"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Current Password" Classes="label"/>
                        <TextBox x:Name="PwdCurrent" PasswordChar="●"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="New Password" Classes="label"/>
                            <TextBox x:Name="PwdNew" PasswordChar="●"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Confirm New Password" Classes="label"/>
                            <TextBox x:Name="PwdConfirm" PasswordChar="●"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Minimum 8 characters, with letters and numbers." FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                    <DockPanel>
                        <TextBlock Text="{Binding PasswordStatus}" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#8B1818" FontSize="12" TextWrapping="Wrap" MaxWidth="360"/>
                        <Button Content="Change Password" Classes="primary" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="OnChangePassword"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
