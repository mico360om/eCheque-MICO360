<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="eCheque.MICO360.Mac.Views.CompanyManagerView">
    <Grid Margin="24" ColumnDefinitions="280,16,*">

        <!-- Company List -->
        <Border Grid.Column="0" Classes="card" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="Companies" FontSize="14" FontWeight="Bold" Foreground="#8B1818" VerticalAlignment="Center"/>
                        <Button Content="+ New" Classes="primary" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Padding="12,6" FontSize="12" Command="{Binding NewCommand}"/>
                    </DockPanel>
                </Border>
                <ListBox ItemsSource="{Binding Companies}"
                         SelectedItem="{Binding Selected}"
                         BorderThickness="0" Background="Transparent" Padding="6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="{Binding TradeName}" FontSize="11" Foreground="#888888"
                                           IsVisible="{Binding TradeName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Edit Form -->
        <Border Grid.Column="2" Classes="card">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Company Details" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,16"/>

                    <!-- Active company badge (view mode) -->
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="0,0,0,14"
                            IsVisible="{Binding IsViewing}">
                        <TextBlock FontSize="12" Foreground="#2E7D32">
                            <Run Text="Selected company: "/>
                            <Run Text="{Binding Selected.Name}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>

                    <Grid Margin="0,0,0,12" ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Company Name *" Classes="label"/>
                            <TextBox Text="{Binding Edit.Name}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Trade Name" Classes="label"/>
                            <TextBox Text="{Binding Edit.TradeName}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Address" Classes="label"/>
                        <TextBox Text="{Binding Edit.Address}" IsEnabled="{Binding IsEditing}"
                                 MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12" ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phone" Classes="label"/>
                            <TextBox Text="{Binding Edit.Phone}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" Classes="label"/>
                            <TextBox Text="{Binding Edit.Email}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,20" ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Default Currency" Classes="label"/>
                            <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding Edit.Currency}"
                                      IsEnabled="{Binding IsEditing}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#8B1818" Margin="0,0,0,12"
                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="✎  Edit" Classes="secondary" Command="{Binding EditCommand}"
                                IsVisible="{Binding IsViewing}"/>
                        <Button Content="🗑  Delete" Classes="secondary" Command="{Binding DeleteCommand}"
                                IsVisible="{Binding IsViewing}"/>
                        <Button Content="Cancel" Classes="secondary" Command="{Binding CancelEditCommand}"
                                IsVisible="{Binding IsEditing}"/>
                        <Button Content="💾  Save Company" Classes="primary" Command="{Binding SaveCommand}"
                                IsVisible="{Binding IsEditing}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
