<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="eCheque.MICO360.Mac.Views.UserManagementView">
    <Grid ColumnDefinitions="300,*" Margin="24">

        <!-- User list -->
        <Border Grid.Column="0" Classes="card" Margin="0,0,14,0" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Users" Classes="cardTitle"/>
                <Button DockPanel.Dock="Bottom" Content="Add New User" Classes="primary"
                        HorizontalAlignment="Stretch" Margin="0,10,0,0"
                        Command="{Binding NewUserCommand}"/>
                <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding Selected}"
                         BorderBrush="#E0E0E0" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,3">
                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="13"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Username}" FontSize="11" Foreground="#888888"/>
                                    <TextBlock Text=" — " FontSize="11" Foreground="#888888"/>
                                    <TextBlock Text="{Binding Role}" FontSize="11" Foreground="#888888"/>
                                    <TextBlock Text="  (inactive)" FontSize="11" Foreground="#8B1818"
                                               IsVisible="{Binding !IsActive}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Editor -->
        <Border Grid.Column="1" Classes="card">
            <StackPanel>
                <TextBlock Text="User Details" Classes="cardTitle"/>

                <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Full Name" Classes="label"/>
                        <TextBox Text="{Binding Edit.FullName}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Username" Classes="label"/>
                        <TextBox Text="{Binding Edit.Username}"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Email" Classes="label"/>
                        <TextBox Text="{Binding Edit.Email}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Role" Classes="label"/>
                        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding Edit.Role}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="New Password (leave blank to keep current)" Classes="label"/>
                        <TextBox x:Name="PwdBox" PasswordChar="●"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="16,0,0,0">
                        <CheckBox Content=" Active" IsChecked="{Binding Edit.IsActive}" MinHeight="34"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Minimum 8 characters, with letters and numbers."
                           FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" DockPanel.Dock="Left" VerticalAlignment="Center"
                               Foreground="#2E7D32" FontSize="12" TextWrapping="Wrap" MaxWidth="360"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Cancel" Classes="secondary" Command="{Binding CancelEditCommand}"/>
                        <Button Content="Save User" Classes="primary" Click="OnSaveUser"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
