<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="eCheque.MICO360.Mac.Views.MainWindow"
        Width="1200" Height="780" MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Title="eCheque MICO360"
        Background="#F5F5F5">
    <Grid ColumnDefinitions="220,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A1A1A">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,18" BorderBrush="#2C2C2C" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="eCheque MICO360" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtCompany" FontSize="11" Foreground="#8B1818" FontWeight="SemiBold" Margin="0,2,0,0"/>
                        <TextBlock x:Name="TxtUser" FontSize="11" Foreground="#777777"/>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Bottom" Padding="10,10" BorderBrush="#2C2C2C" BorderThickness="0,1,0,0">
                    <Button Content="Logout" Classes="nav" Click="OnLogout"/>
                </Border>
                <StackPanel Margin="8,10">
                    <TextBlock Text="MAIN" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,4,0,4"/>
                    <Button Content="🏠  Dashboard" Classes="nav" Click="NavDashboard"/>
                    <Button x:Name="BtnNewCheque" Content="✚  New Cheque" Classes="nav" Click="NavNewCheque"/>
                    <Button Content="☰  Cheque History" Classes="nav" Click="NavHistory"/>
                    <Button Content="📅  Cheque Tracking" Classes="nav" Click="NavTracking"/>
                    <Button Content="🖨  Print History" Classes="nav" Click="NavPrintHistory"/>
                    <TextBlock x:Name="TxtAdminHdr" Text="ADMINISTRATION" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,14,0,4"/>
                    <Button x:Name="BtnAudit" Content="📋  Audit Log" Classes="nav" Click="NavAudit"/>
                    <TextBlock Text="ACCOUNT" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,14,0,4"/>
                    <Button Content="👤  My Profile" Classes="nav" Click="NavMyProfile"/>
                    <TextBlock Text="HELP &amp; LEGAL" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,14,0,4"/>
                    <Button Content="🔄  Software Updates" Classes="nav" Click="NavUpdates"/>
                    <Button Content="📜  Terms &amp; Legal" Classes="nav" Click="NavLegal"/>
                    <Button Content="ℹ  About" Classes="nav" Click="NavAbout"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="24,12">
                <DockPanel>
                    <TextBlock x:Name="TxtTitle" Text="Dashboard" Classes="h1" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="🏢" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CmbCompanySwitch" MinWidth="170" SelectionChanged="OnCompanySwitch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock x:Name="TxtClock" Foreground="#888888" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <ContentControl x:Name="ContentArea" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>
