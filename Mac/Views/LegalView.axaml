<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="eCheque.MICO360.Mac.Views.LegalView">
    <Grid RowDefinitions="*,Auto">

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel Margin="24,20,24,12" MaxWidth="900" HorizontalAlignment="Stretch">
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding LastUpdated, StringFormat='Last updated: {0}'}"
                                   FontSize="12" Foreground="#888888" Margin="0,0,0,14"/>
                        <Border Height="1" Background="#EEEEEE" Margin="0,0,0,14"/>

                        <!-- View mode -->
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                   FontSize="13" Foreground="#333333" LineHeight="20"
                                   IsVisible="{Binding IsViewing}"/>

                        <!-- Edit mode (admins) -->
                        <TextBox Text="{Binding Content}" IsVisible="{Binding IsEditing}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="360"
                                 VerticalContentAlignment="Top" FontSize="13" Padding="10"
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky action bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <DockPanel Margin="24,10">
                <TextBlock Text="{Binding StatusMessage}" DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="#2E7D32" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="← Back" Classes="secondary" Command="{Binding BackCommand}"/>
                    <Button Content="✎  Edit" Classes="secondary" Command="{Binding EditCommand}" IsVisible="{Binding ShowEdit}"/>
                    <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}" IsVisible="{Binding IsEditing}"/>
                    <Button Content="💾  Save" Classes="primary" Command="{Binding SaveCommand}" IsVisible="{Binding IsEditing}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
