<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="eCheque.MICO360.Mac.Views.UpdateView">
    <ScrollViewer>
        <StackPanel Margin="24,20" MaxWidth="760" HorizontalAlignment="Stretch">

            <!-- Version summary -->
            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Software Updates" Classes="cardTitle"/>
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Installed Version" Classes="label"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Latest Version" Classes="label"/>
                            <TextBlock Text="{Binding LatestVersion}" FontSize="20" FontWeight="Bold" Foreground="{Binding LatestVersionBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Download Size" Classes="label"/>
                            <TextBlock Text="{Binding SizeDisplay}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                        </StackPanel>
                    </Grid>

                    <!-- Mandatory badge -->
                    <Border Background="#FDECEA" BorderBrush="#F5C6CB" BorderThickness="1" CornerRadius="4"
                            Padding="10,7" Margin="0,14,0,0" HorizontalAlignment="Left"
                            IsVisible="{Binding IsMandatory}">
                        <TextBlock Text="⚠  This is a required update and must be installed to continue using the app."
                                   FontSize="12" Foreground="#B00020" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Up-to-date chip (shown only when a check found no newer version) -->
                    <Border Background="#E9F7EC" BorderBrush="#B7E1C1" BorderThickness="1" CornerRadius="4"
                            Padding="10,7" Margin="0,14,0,0" HorizontalAlignment="Left"
                            IsVisible="{Binding UpToDate}">
                        <TextBlock Text="✔  You have the latest version installed — no update needed."
                                   FontSize="12" Foreground="#2E7D32" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Status line (colour reflects state: green = good, red = error, grey = info) -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{Binding StatusBrush}"
                               Margin="0,14,0,0" TextWrapping="Wrap"/>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Check for Updates" Classes="secondary" Margin="0,0,8,0"
                                Command="{Binding CheckCommand}" IsEnabled="{Binding IsNotBusy}"/>
                        <Button Content="Download Latest from GitHub" Classes="primary"
                                Command="{Binding OpenReleasesCommand}"
                                IsVisible="{Binding UpdateAvailable}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Changelog -->
            <Border Classes="card" Margin="0,0,0,16" IsVisible="{Binding HasChecked}">
                <StackPanel>
                    <TextBlock Text="What's New" Classes="cardTitle"/>
                    <TextBlock Text="{Binding Changelog}" TextWrapping="Wrap" FontSize="13" Foreground="#333333" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- Manual update via GitHub -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Text="Update Manually" Classes="cardTitle"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#444444" Margin="0,0,0,10"
                               Text="There is no in-app installer on macOS. Download the latest release directly from the official GitHub repository, then open the .dmg / .zip and drag the app into your Applications folder."/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Repository: " FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
                        <Button Content="{Binding RepoUrl}" Command="{Binding OpenRepoCommand}"
                                Background="Transparent" Foreground="#1565C0" Padding="0" Cursor="Hand"
                                BorderThickness="0" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Download Latest from GitHub" Classes="primary"
                                Command="{Binding OpenReleasesCommand}" Margin="0,0,8,0"/>
                        <Button Content="Open Repository" Classes="secondary"
                                Command="{Binding OpenRepoCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Updates are downloaded from the official repository. Your database, settings, profiles and records are never modified by an update."
                       FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="2,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
