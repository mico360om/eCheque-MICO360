<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="eCheque.MICO360.Mac.Views.MessageDialog"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Notice"
        Background="White">
    <StackPanel Margin="22">
        <TextBlock x:Name="TxtHeading" FontSize="16" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,8"/>
        <TextBlock x:Name="TxtBody" TextWrapping="Wrap" FontSize="13" Foreground="#333333"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,18,0,0">
            <Button x:Name="BtnSecondary" Classes="secondary" Click="OnSecondary"/>
            <Button x:Name="BtnPrimary" Classes="primary" Click="OnPrimary"/>
        </StackPanel>
    </StackPanel>
</Window>
