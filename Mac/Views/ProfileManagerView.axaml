<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="eCheque.MICO360.Mac.Views.ProfileManagerView">
    <Grid Margin="24" ColumnDefinitions="280,16,*">

        <!-- Profile List -->
        <Border Grid.Column="0" Classes="card" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="Cheque Profiles" FontSize="14" FontWeight="Bold" Foreground="#8B1818" VerticalAlignment="Center"/>
                        <Button Content="+ New" Classes="primary" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Padding="12,6" FontSize="12" Command="{Binding NewCommand}"/>
                    </DockPanel>
                </Border>
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding Selected}"
                         BorderThickness="0" Background="Transparent" Padding="6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="{Binding BankName}" FontSize="11" Foreground="#888888"
                                           IsVisible="{Binding BankName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Edit Form -->
        <Border Grid.Column="2" Classes="card">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Profile Details" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,16"/>

                    <!-- Selected profile badge (view mode) -->
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="0,0,0,14"
                            IsVisible="{Binding IsViewing}">
                        <TextBlock FontSize="12" Foreground="#2E7D32">
                            <Run Text="Selected profile: "/>
                            <Run Text="{Binding Selected.Name}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>

                    <Grid Margin="0,0,0,12" ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Profile Name *" Classes="label"/>
                            <TextBox Text="{Binding Edit.Name}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Bank Name" Classes="label"/>
                            <ComboBox ItemsSource="{Binding Banks}" SelectedItem="{Binding Edit.BankName}"
                                      IsEnabled="{Binding IsEditing}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12" ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Account Name" Classes="label"/>
                            <TextBox Text="{Binding Edit.AccountName}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Account Number" Classes="label"/>
                            <TextBox Text="{Binding Edit.AccountNumber}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Cheque Paper" FontSize="13" FontWeight="Bold" Foreground="#444444" Margin="0,6,0,10"/>

                    <Grid Margin="0,0,0,12" ColumnDefinitions="*,12,*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Cheque Width (mm)" Classes="label"/>
                            <TextBox Text="{Binding Edit.ChequeWidth}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Cheque Height (mm)" Classes="label"/>
                            <TextBox Text="{Binding Edit.ChequeHeight}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Print Paper" Classes="label"/>
                            <ComboBox ItemsSource="{Binding PaperSizes}" SelectedItem="{Binding Edit.PaperSize}"
                                      IsEnabled="{Binding IsEditing}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Font" FontSize="13" FontWeight="Bold" Foreground="#444444" Margin="0,6,0,10"/>

                    <Grid Margin="0,0,0,12" ColumnDefinitions="*,12,*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Font Family" Classes="label"/>
                            <ComboBox ItemsSource="{Binding FontFamilies}" SelectedItem="{Binding Edit.FontFamily}"
                                      IsEnabled="{Binding IsEditing}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Font Size" Classes="label"/>
                            <TextBox Text="{Binding Edit.FontSize}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                            <CheckBox Content=" Bold" IsChecked="{Binding Edit.IsBold}" IsEnabled="{Binding IsEditing}" MinHeight="34"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Print Nudge" FontSize="13" FontWeight="Bold" Foreground="#444444" Margin="0,6,0,10"/>

                    <Grid Margin="0,0,0,20" ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Print Nudge X (mm)" Classes="label"/>
                            <TextBox Text="{Binding Edit.PrintOffsetX}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Print Nudge Y (mm)" Classes="label"/>
                            <TextBox Text="{Binding Edit.PrintOffsetY}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#8B1818" Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="🎨  Design Layout" Classes="secondary" Command="{Binding DesignLayoutCommand}"
                                IsVisible="{Binding IsViewing}"/>
                        <Button Content="⧉  Duplicate" Classes="secondary" Command="{Binding DuplicateCommand}"
                                IsVisible="{Binding IsViewing}"/>
                        <Button Content="🗑  Delete" Classes="secondary" Command="{Binding DeleteCommand}"
                                IsVisible="{Binding IsViewing}"/>
                        <Button Content="Cancel" Classes="secondary" Command="{Binding CancelEditCommand}"
                                IsVisible="{Binding IsEditing}"/>
                        <Button Content="💾  Save Profile" Classes="primary" Command="{Binding SaveCommand}"
                                IsVisible="{Binding IsEditing}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
