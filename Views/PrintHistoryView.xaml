<UserControl x:Class="eCheque.MICO360.Views.PrintHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Filters -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Search (cheque, payee, user, reason)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filter by cheque number, payee, user, or reason"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Bank" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Banks}" SelectedItem="{Binding BankFilter}"
                                  ToolTip="Show prints for the selected bank only"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Types}" SelectedItem="{Binding TypeFilter}"
                                  ToolTip="Filter by print type — original or reprint"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="From Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding From}" FontSize="13" Padding="6,5"
                                    ToolTip="Show prints on or after this date"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="To Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding To}" FontSize="13" Padding="6,5"
                                    ToolTip="Show prints on or before this date"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Clear Filters" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Command="{Binding ClearFiltersCommand}"
                            ToolTip="Reset search, bank, type, and date filters"/>
                    <Button Content="Refresh" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Command="{Binding RefreshCommand}"/>
                    <Button Content="⬇  Export Excel" Style="{StaticResource PrimaryBtn}" Command="{Binding ExportCommand}"
                            ToolTip="Export the current filtered list to Excel"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <!-- Grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding History}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Printed Date" Binding="{Binding PrintedDate, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="155"/>
                        <DataGridTextColumn Header="Cheque #" Binding="{Binding ChequeNumber}" Width="100"/>
                        <DataGridTextColumn Header="Payee Name" Binding="{Binding PayeeName}" Width="*"/>
                        <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="130"/>
                        <DataGridTextColumn Header="Amount (OMR)" Binding="{Binding Amount, StringFormat=N3}" Width="110"/>
                        <DataGridTextColumn Header="Printed By" Binding="{Binding PrintedBy}" Width="110"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding ReprintLabel}" Width="85"/>
                        <DataGridTextColumn Header="Reason / Notes" Binding="{Binding Reason}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="🖨" FontSize="34" HorizontalAlignment="Center" Foreground="#CCCCCC"/>
                    <TextBlock Text="No print records found" FontSize="14" FontWeight="SemiBold" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,8,0,2"/>
                    <TextBlock Text="Printed and reprinted cheques will appear here." FontSize="12" Foreground="#AAAAAA"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12" Foreground="#888888"
                   Text="{Binding History.Count, StringFormat='{}{0} print record(s)'}"/>
    </Grid>
</UserControl>
