<UserControl x:Class="eCheque.MICO360.Views.LegalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel Margin="24,20,24,12" MaxWidth="900" HorizontalAlignment="Left">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Title row -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold"
                                       Foreground="#8B1818" DockPanel.Dock="Left"/>
                        </DockPanel>
                        <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,14">
                            <Run Text="Last updated:"/>
                            <Run Text="{Binding LastUpdated}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Border Height="1" Background="#EEEEEE" Margin="0,0,0,14"/>

                        <!-- View mode -->
                        <TextBlock x:Name="ContentText" Text="{Binding Content}" TextWrapping="Wrap"
                                   FontSize="13" Foreground="#333333" LineHeight="20"
                                   Visibility="{Binding IsViewing, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Edit mode (admins) -->
                        <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="360"
                                 VerticalScrollBarVisibility="Auto" FontSize="13" Padding="10"
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky action bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="8" ShadowDepth="2" Direction="90" Opacity="0.2"/>
            </Border.Effect>
            <DockPanel Margin="24,10">
                <TextBlock Text="{Binding StatusMessage}" DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="#2E7D32" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="← Back" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding BackCommand}"/>
                    <Button Content="🖨  Print / Export PDF" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Click="BtnPrint_Click"
                            Visibility="{Binding IsViewing, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="✎  Edit" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding EditCommand}"
                            Visibility="{Binding ShowEdit, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="💾  Save" Style="{StaticResource PrimaryBtn}"
                            Command="{Binding SaveCommand}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
