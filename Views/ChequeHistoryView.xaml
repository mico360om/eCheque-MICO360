<UserControl x:Class="eCheque.MICO360.Views.ChequeHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Filters -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Search" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="TxtSearch"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding StatusFilter}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="From Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding From}" FontSize="13" Padding="6,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="To Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding To}" FontSize="13" Padding="6,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                        <Button Content="Export Excel" Style="{StaticResource SecondaryBtn}"
                                Command="{Binding ExportCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <!-- Grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Cheques}" SelectedItem="{Binding Selected}"
                      Padding="0" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cheque #" Binding="{Binding ChequeNumber}" Width="100"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding ChequeDate, StringFormat=dd/MM/yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Payee Name" Binding="{Binding PayeeName}" Width="*"/>
                    <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="130"/>
                    <DataGridTextColumn Header="Amount (OMR)" Binding="{Binding Amount, StringFormat=N3}" Width="110"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                    <DataGridTextColumn Header="Prints" Binding="{Binding PrintCount}" Width="55"/>
                    <DataGridTemplateColumn Header="Actions" Width="230">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <Button Content="Print" Style="{StaticResource PrimaryBtn}" Padding="8,3" Margin="0,0,4,0" FontSize="11"
                                            Command="{Binding DataContext.PrintCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Edit" Style="{StaticResource SecondaryBtn}" Padding="8,3" Margin="0,0,4,0" FontSize="11"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Cancel" Foreground="#8B1818" Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" FontSize="11" Padding="4,3" Margin="0,0,4,0"
                                            Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Void" Foreground="#B00020" Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" FontSize="11" Padding="4,3"
                                            Command="{Binding DataContext.VoidCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <!-- Status Bar -->
        <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12" Foreground="#888888"
                   Text="{Binding Cheques.Count, StringFormat='{}{0} record(s)'}"/>
    </Grid>
</UserControl>

