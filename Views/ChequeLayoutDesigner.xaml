<Window x:Class="eCheque.MICO360.Views.ChequeLayoutDesigner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cheque Visualizer — eCheque MICO360"
        Width="1120" Height="720" MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Icon="/logo.ico"
        Background="#F5F5F5"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="14,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtProfileName" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Upload your scanned cheque, then drag each field onto it." FontSize="11" Foreground="#999999"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🖼 Upload Cheque Image" Click="BtnUpload_Click" Style="{StaticResource SecondaryBtn}"
                            Foreground="White" BorderBrush="#666" Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="✕ Remove" Click="BtnRemoveImage_Click" Style="{StaticResource SecondaryBtn}"
                            Foreground="White" BorderBrush="#666" Padding="8,5" Margin="0,0,12,0"/>
                    <Button Content="−" Click="BtnZoomOut_Click" Style="{StaticResource SecondaryBtn}" Foreground="White" BorderBrush="#666" Padding="10,3" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtZoom" Text="100%" Foreground="White" FontSize="12" VerticalAlignment="Center" MinWidth="42" TextAlignment="Center"/>
                    <Button Content="+" Click="BtnZoomIn_Click" Style="{StaticResource SecondaryBtn}" Foreground="White" BorderBrush="#666" Padding="10,3" Margin="4,0,4,0"/>
                    <Button Content="Fit" Click="BtnFit_Click" Style="{StaticResource SecondaryBtn}" Foreground="White" BorderBrush="#666" Padding="10,3" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkGrid" Content="Grid" Foreground="White" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Click="ChkGrid_Click"/>
                    <Button Content="🖨 Test Print" Click="BtnTestPrint_Click" Style="{StaticResource SecondaryBtn}" Foreground="White" BorderBrush="#666" Padding="10,5"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main: canvas + properties -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer x:Name="CanvasScroller" Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          Background="#6E6E6E" Padding="24" SizeChanged="CanvasScroller_SizeChanged">
                <Border BorderBrush="#444" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
                    <Grid>
                        <Image x:Name="BgImage" Stretch="Fill" SnapsToDevicePixels="True"/>
                        <Canvas x:Name="ChequeCanvas" Background="Transparent"
                                MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseLeftButtonUp" Cursor="Arrow"/>
                    </Grid>
                </Border>
            </ScrollViewer>

            <!-- Properties panel -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="14,10" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                        <TextBlock Text="Field Properties" FontSize="13" FontWeight="Bold" Foreground="#8B1818"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14,12">
                            <!-- Add field -->
                            <TextBlock Text="Fields on cheque" Style="{StaticResource FieldLabel}"/>
                            <ListBox x:Name="LstFields" Height="150" Margin="0,0,0,10" SelectionChanged="LstFields_SelectionChanged"
                                     DisplayMemberPath="Label" BorderBrush="#DDD" BorderThickness="1"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <ComboBox x:Name="CmbAddField" Width="150" Margin="0,0,6,0" FontSize="12"/>
                                <Button Content="+ Add" Click="BtnAddField_Click" Style="{StaticResource SecondaryBtn}" Padding="10,4" FontSize="12"/>
                            </StackPanel>

                            <Border Height="1" Background="#EEE" Margin="0,0,0,12"/>

                            <!-- Selected field editor -->
                            <StackPanel x:Name="PanelProps" IsEnabled="False">
                                <CheckBox x:Name="ChkEnabled" Content="Print this field" Margin="0,0,0,10" Click="Prop_Changed"/>
                                <TextBlock Text="Label / Custom text" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtLabel" Style="{StaticResource InputBox}" Margin="0,0,0,10" TextChanged="Prop_Changed"/>
                                <TextBlock Text="Font family" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbFont" Style="{StaticResource InputCombo}" Margin="0,0,0,10" SelectionChanged="Prop_Changed"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Font size" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtSize" Style="{StaticResource InputBox}" TextChanged="Prop_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Width (mm)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtWidth" Style="{StaticResource InputBox}" TextChanged="Prop_Changed"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Alignment" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbAlign" Style="{StaticResource InputCombo}" Margin="0,0,0,10" SelectionChanged="Prop_Changed">
                                    <ComboBoxItem Content="Left"/><ComboBoxItem Content="Center"/><ComboBoxItem Content="Right"/>
                                </ComboBox>
                                <CheckBox x:Name="ChkBold" Content="Bold" Margin="0,0,0,12" Click="Prop_Changed"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="X (mm)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtX" Style="{StaticResource InputBox}" TextChanged="Prop_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Y (mm)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtY" Style="{StaticResource InputBox}" TextChanged="Prop_Changed"/>
                                    </StackPanel>
                                </Grid>
                                <Button x:Name="BtnDeleteField" Content="🗑  Remove this field  (Del)" Click="BtnDeleteField_Click"
                                        Style="{StaticResource SecondaryBtn}" Foreground="#CC2020" BorderBrush="#CC2020" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Position info -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,1" Padding="16,6">
            <TextBlock x:Name="TxtPosition" FontSize="12" Foreground="#555555"
                       Text="Drag a field to position it. Only entered data prints at these positions — the background image is a guide and is never printed."/>
        </Border>

        <!-- Action buttons -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="Reset to Defaults" Style="{StaticResource SecondaryBtn}" Click="BtnReset_Click" Padding="14,7"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                    <Button Content="💾 Save Layout" Style="{StaticResource PrimaryBtn}" Click="BtnSave_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
