<UserControl x:Class="eCheque.MICO360.Views.ChequeTrackingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Mode switch -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="📅  PDC Register" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Command="{Binding ShowPdcCommand}"/>
                    <Button Content="✓  Reconciliation" Style="{StaticResource SecondaryBtn}" Command="{Binding ShowReconCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="⭳  Export CSV" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Command="{Binding ExportCommand}"/>
                    <Button Content="Refresh" Style="{StaticResource SecondaryBtn}" Command="{Binding RefreshCommand}"/>
                </StackPanel>
                <TextBlock Text="{Binding Heading}" VerticalAlignment="Center" Margin="16,0" Foreground="#8B1818" FontWeight="SemiBold" FontSize="13"/>
            </DockPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Cheques}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cheque #" Binding="{Binding ChequeNumber}" Width="100"/>
                        <DataGridTextColumn Header="Cheque Date" Binding="{Binding ChequeDate, StringFormat=dd/MM/yyyy}" Width="105"/>
                        <DataGridTextColumn Header="Due" Binding="{Binding DueLabel}" Width="90"/>
                        <DataGridTextColumn Header="Payee" Binding="{Binding PayeeName}" Width="*"/>
                        <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="120"/>
                        <DataGridTextColumn Header="Amount (OMR)" Binding="{Binding Amount, StringFormat=N3}" Width="105"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        <DataGridTemplateColumn Header="Update" Width="215">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Button Content="Present" Style="{StaticResource SecondaryBtn}" Padding="7,3" Margin="0,0,4,0" FontSize="11"
                                                Command="{Binding DataContext.PresentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                        <Button Content="Clear" Style="{StaticResource PrimaryBtn}" Padding="7,3" Margin="0,0,4,0" FontSize="11"
                                                Command="{Binding DataContext.ClearedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                        <Button Content="Bounce" Foreground="#B00020" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="11" Padding="4,3"
                                                Command="{Binding DataContext.BounceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="📅" FontSize="34" HorizontalAlignment="Center" Foreground="#CCCCCC"/>
                    <TextBlock Text="Nothing to show here" FontSize="14" FontWeight="SemiBold" Foreground="#888888" HorizontalAlignment="Center" Margin="0,8,0,2"/>
                    <TextBlock Text="Post-dated and outstanding cheques will appear here." FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" DockPanel.Dock="Left" Foreground="#2E7D32" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SummaryText}" DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="#8B1818"/>
        </DockPanel>
    </Grid>
</UserControl>
