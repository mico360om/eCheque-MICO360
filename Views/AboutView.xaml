<UserControl x:Class="eCheque.MICO360.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel Margin="24,20,24,12" MaxWidth="780" HorizontalAlignment="Left">

                <!-- Identity card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Image Source="/logo.png" Height="56" Stretch="Uniform" VerticalAlignment="Center"/>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold" Foreground="#8B1818"/>
                                <TextBlock Text="{Binding Version}" FontSize="13" Foreground="#888888"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="#EEEEEE" Margin="0,6,0,14"/>

                        <TextBlock Text="About" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding Intro}" TextWrapping="Wrap" FontSize="13" Foreground="#333333"
                                   LineHeight="20" Margin="0,0,0,4"
                                   Visibility="{Binding IsViewing, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBox Text="{Binding Intro, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                 VerticalScrollBarVisibility="Auto" FontSize="13" Padding="10"
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <!-- Company / contact card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Company &amp; Contact" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Application" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppName}" FontSize="13" Foreground="#333333" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Company" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CompanyName}" FontSize="13" Foreground="#333333" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Contact Email" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ContactEmail}" FontSize="13" Foreground="#1565C0" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Website" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Website}" FontSize="13" Foreground="#1565C0" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="App Version" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Version}" FontSize="13" Foreground="#333333"/>
                        </Grid>
                        <Border Height="1" Background="#EEEEEE" Margin="0,14,0,10"/>
                        <TextBlock FontSize="11" Foreground="#AAAAAA">
                            <Run Text="Last updated:"/>
                            <Run Text="{Binding LastUpdated}"/>
                        </TextBlock>
                        <TextBlock Text="© 2026 MICO360 Softwares. All rights reserved." FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky action bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="8" ShadowDepth="-2" Opacity="0.2"/>
            </Border.Effect>
            <DockPanel Margin="24,10">
                <TextBlock Text="{Binding StatusMessage}" DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="#2E7D32" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="← Back" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding BackCommand}"/>
                    <Button Content="🖨  Print / Export PDF" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Click="BtnPrint_Click"
                            Visibility="{Binding IsViewing, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="✎  Edit" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding EditCommand}"
                            Visibility="{Binding ShowEdit, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="💾  Save" Style="{StaticResource PrimaryBtn}"
                            Command="{Binding SaveCommand}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
