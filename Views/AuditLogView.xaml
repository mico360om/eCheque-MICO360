<UserControl x:Class="eCheque.MICO360.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filters -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Search (user, action, reference, remarks)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Action" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Actions}" SelectedItem="{Binding ActionFilter}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="From Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding From}" FontSize="13" Padding="6,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="To Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding To}" FontSize="13" Padding="6,5"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Clear Filters" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Command="{Binding ClearFiltersCommand}"/>
                    <Button Content="Refresh" Style="{StaticResource SecondaryBtn}" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Logs}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date/Time" Binding="{Binding ActionDate, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="150"/>
                        <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="120"/>
                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="160"/>
                        <DataGridTextColumn Header="Reference" Binding="{Binding RecordReference}" Width="130"/>
                        <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="📋" FontSize="34" HorizontalAlignment="Center" Foreground="#CCCCCC"/>
                    <TextBlock Text="No audit records found" FontSize="14" FontWeight="SemiBold" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="12" Foreground="#888888"
                   Text="{Binding Logs.Count, StringFormat='{}{0} audit record(s)'}"/>
    </Grid>
</UserControl>
