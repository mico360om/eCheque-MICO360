<UserControl x:Class="eCheque.MICO360.Views.UpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20" MaxWidth="760" HorizontalAlignment="Stretch">

            <!-- Version summary -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Software Updates" FontSize="18" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Installed Version" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Latest Version" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding LatestVersion, TargetNullValue='—'}" FontSize="20" FontWeight="Bold" Foreground="{Binding LatestVersionBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Download Size" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding SizeDisplay, TargetNullValue='—'}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                        </StackPanel>
                    </Grid>

                    <!-- Mandatory badge -->
                    <Border Background="#FDECEA" BorderBrush="#F5C6CB" BorderThickness="1" CornerRadius="4"
                            Padding="10,7" Margin="0,14,0,0"
                            Visibility="{Binding IsMandatory, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="⚠  This is a required update and must be installed to continue using the app."
                                   FontSize="12" Foreground="#B00020" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Up-to-date chip (green, shown only when a check found no newer version) -->
                    <Border Background="#E9F7EC" BorderBrush="#B7E1C1" BorderThickness="1" CornerRadius="4"
                            Padding="10,7" Margin="0,14,0,0" HorizontalAlignment="Left"
                            Visibility="{Binding UpToDate, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="✔  You have the latest version installed — no update needed."
                                   FontSize="12" Foreground="#2E7D32" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Status + progress (colour reflects state: green = good, red = error, grey = info) -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{Binding StatusBrush}"
                               Margin="0,14,0,0" TextWrapping="Wrap"/>
                    <ProgressBar Height="10" Margin="0,10,0,0" Minimum="0" Maximum="100" Value="{Binding Progress}"
                                 Foreground="#8B1818" Background="#EEEEEE" BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="🔄  Check for Updates" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                                Command="{Binding CheckCommand}" IsEnabled="{Binding IsNotBusy}"/>
                        <Button Content="⬇  Download &amp; Install" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"
                                Command="{Binding InstallCommand}"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="View Update Log" Style="{StaticResource SecondaryBtn}"
                                Command="{Binding ViewLogCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Changelog -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding HasChecked, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="What's New" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding Changelog}" TextWrapping="Wrap" FontSize="13" Foreground="#333333" LineHeight="20"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Updates are downloaded from the official repository and verified before installation. Your database, settings, profiles and records are never modified by an update."
                       FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="2,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
