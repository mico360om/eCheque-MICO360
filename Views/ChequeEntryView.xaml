<UserControl x:Class="eCheque.MICO360.Views.ChequeEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Scrollable form ── -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,8" MaxWidth="920">

                <!-- Card 1: Cheque Profile -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Cheque Profile" FontSize="13" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Profile *" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Style="{StaticResource InputCombo}"
                                          ItemsSource="{Binding Profiles}"
                                          SelectedItem="{Binding SelectedProfile}"
                                          DisplayMemberPath="Name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Bank Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.BankName}"
                                         IsReadOnly="True" Background="#F8F8F8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Account Number" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.AccountNumber}"
                                         IsReadOnly="True" Background="#F8F8F8"/>
                            </StackPanel>
                        </Grid>
                        <!-- Profile info banner -->
                        <Border Background="#FFF8F0" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="4"
                                Padding="10,7" Margin="0,10,0,0"
                                Visibility="{Binding HasProfile, Converter={StaticResource BoolToVisibility}}">
                            <DockPanel>
                                <TextBlock Text="ℹ " Foreground="#E65100" FontSize="13" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ProfileInfo}" FontSize="11" Foreground="#BF360C"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Card 2: Cheque Details -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Cheque Details" FontSize="13" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>

                        <!-- Row: Cheque #, Date, Status -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Cheque Number *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtChequeNumber" Style="{StaticResource InputBox}"
                                         Text="{Binding Cheque.ChequeNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Date *" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding Cheque.ChequeDate}" FontSize="13" Padding="6,6"
                                            BorderBrush="#CCCCCC" BorderThickness="1" Background="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.Status}"
                                         IsReadOnly="True" Background="#F8F8F8"/>
                            </StackPanel>
                        </Grid>

                        <!-- Payee Name — autocomplete ComboBox -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Payee Name *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbPayee" IsEditable="True"
                                      ItemsSource="{Binding Payees}"
                                      Text="{Binding Cheque.PayeeName, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                      FontSize="13" Padding="8,7"
                                      Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                      MaxDropDownHeight="200"/>
                        </StackPanel>

                        <!-- Amount + Amount in Words -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Amount (OMR) *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtAmount" Style="{StaticResource InputBox}"
                                         LostFocus="AmountBox_LostFocus"
                                         TextChanged="AmountBox_TextChanged"
                                         FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <DockPanel Margin="0,0,0,3">
                                    <TextBlock Text="Amount in Words" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="(auto-updates on amount entry)" FontSize="10"
                                               Foreground="#AAAAAA" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </DockPanel>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding Cheque.AmountInWords, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" Height="46" FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <!-- Memo -->
                        <StackPanel>
                            <DockPanel Margin="0,0,0,3">
                                <TextBlock Text="Memo / Narration" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtMemoCount" Text="0 / 250" FontSize="10"
                                           Foreground="#AAAAAA" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBox x:Name="TxtMemo" Style="{StaticResource InputBox}"
                                     Text="{Binding Cheque.Remarks, UpdateSourceTrigger=PropertyChanged}"
                                     Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                     MaxLength="250" VerticalScrollBarVisibility="Auto"
                                     TextChanged="MemoBox_TextChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 3: Reference Details — collapsible -->
                <Expander x:Name="RefExpander" Background="White"
                          BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,12">
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Expander">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <DockPanel>
                                                <ToggleButton x:Name="HeaderSite" DockPanel.Dock="Top"
                                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                              Padding="18,12">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <DockPanel>
                                                                    <TextBlock DockPanel.Dock="Right" FontSize="12" Foreground="#888888" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="▶  Show Reference Details"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                                        <Setter Property="Text" Value="▼  Hide Reference Details"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Text="Reference Details (Optional)" FontSize="13" FontWeight="Bold"
                                                                               Foreground="#8B1818" VerticalAlignment="Center"/>
                                                                </DockPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <ContentPresenter DockPanel.Dock="Bottom" x:Name="ExpandSite"
                                                                  Visibility="Collapsed" Margin="18,0,18,14"/>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Expander.Style>
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Reference Number" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.ReferenceNumber}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Invoice Number" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.InvoiceNumber}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Voucher Number" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.VoucherNumber}"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Department" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.Department}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Prepared By" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.PreparedBy}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Approved By" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Cheque.ApprovedBy}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Sticky action bar ── -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="8" ShadowDepth="-2" Opacity="0.2"/>
            </Border.Effect>
            <DockPanel Margin="20,10">
                <!-- Status / error message on left -->
                <TextBlock Text="{Binding StatusMessage}" DockPanel.Dock="Left"
                           VerticalAlignment="Center" FontSize="12" MaxWidth="480"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CC2020"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <!-- Buttons right-aligned -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource SecondaryBtn}"
                            Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                    <Button Content="💾  Save Draft" Style="{StaticResource SecondaryBtn}"
                            Margin="0,0,8,0" Command="{Binding SaveDraftCommand}"/>
                    <Button Margin="0,0,8,0" Command="{Binding PreviewCommand}"
                            Padding="16,8" Background="#1565C0" Foreground="White"
                            FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1976D2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="👁  Preview Cheque"/>
                    </Button>
                    <Button Content="🖨  Print Cheque" Style="{StaticResource PrimaryBtn}"
                            Padding="16,8" Command="{Binding SavePrintCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
