<UserControl x:Class="eCheque.MICO360.Views.CompanyManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Company List -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="Companies" FontSize="14" FontWeight="Bold" Foreground="#8B1818" VerticalAlignment="Center"/>
                        <Button Content="+ New" Style="{StaticResource PrimaryBtn}" DockPanel.Dock="Right"
                                Padding="10,5" FontSize="12" Command="{Binding NewCommand}"/>
                    </DockPanel>
                </Border>
                <ListBox ItemsSource="{Binding Companies}"
                         SelectedItem="{Binding Selected}"
                         BorderThickness="0" Background="Transparent"
                         Padding="6,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="{Binding TradeName}" FontSize="11" Foreground="#888888"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FFE8E8"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFF5F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Edit Form -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Company Details" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,16"/>

                    <!-- Active company badge -->
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="0,0,0,14"
                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock FontSize="12" Foreground="#2E7D32">
                            <Run Text="Active company: "/>
                            <Run Text="{Binding Selected.Name}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Company Name *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Name}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Trade Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.TradeName}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Address}" IsEnabled="{Binding IsEditing}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Phone}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Email}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,20" HorizontalAlignment="Left" Width="160">
                        <TextBlock Text="Default Currency" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Currencies}"
                                  SelectedItem="{Binding Edit.Currency}" IsEnabled="{Binding IsEditing}"/>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#8B1818" Margin="0,0,0,12"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Edit" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0"
                                Command="{Binding NewCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <Button Content="Delete" Margin="0,0,10,0" Padding="16,7"
                                Foreground="#CC2020" Background="Transparent" BorderBrush="#CC2020" BorderThickness="1"
                                Cursor="Hand" Command="{Binding DeleteCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFEEEE"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Foreground" Value="#BBBBBB"/>
                                                        <Setter Property="BorderBrush" Value="#BBBBBB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0"
                                Command="{Binding CancelEditCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="Save Company" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SaveCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
