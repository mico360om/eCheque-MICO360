<UserControl x:Class="eCheque.MICO360.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- User List -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Users" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>
                <Button DockPanel.Dock="Bottom" Content="Add New User" Style="{StaticResource PrimaryBtn}"
                        Margin="0,8,0,0" Command="{Binding NewUserCommand}"/>
                <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding Selected}"
                         BorderThickness="1" BorderBrush="#E0E0E0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,3">
                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                                <TextBlock FontSize="11" Foreground="#888888">
                                    <Run Text="{Binding Username}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding Role}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE8E8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>
        <!-- Editor -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="User Details" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,14"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Full Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.FullName}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Username}"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Email}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Role" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Roles}"
                                  SelectedItem="{Binding Edit.Role}"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="New Password (leave blank to keep current)" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="PwdBox" Style="{StaticResource InputPassword}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="16,0,0,0">
                        <CheckBox Content=" Active" IsChecked="{Binding Edit.IsActive}" VerticalAlignment="Center" MinHeight="34" Padding="0,7,0,0"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                            Command="{Binding CancelEditCommand}"/>
                    <Button Content="Save User" Style="{StaticResource PrimaryBtn}"
                            Command="{Binding SaveUserCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

