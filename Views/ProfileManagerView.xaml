<UserControl x:Class="eCheque.MICO360.Views.ProfileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Profile List -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Profiles" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="＋  New Profile" Style="{StaticResource PrimaryBtn}" Padding="12,8" FontSize="12"
                            HorizontalAlignment="Stretch" Margin="0,0,0,6" Command="{Binding NewCommand}"/>
                    <Button Content="⧉  Duplicate Selected" Style="{StaticResource SecondaryBtn}" Padding="10,7" FontSize="12"
                            HorizontalAlignment="Stretch" Command="{Binding DuplicateCommand}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding Selected}"
                         BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,3">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding BankName}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE8E8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Profile Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Basic details -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Profile Details" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Profile Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Name, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Bank Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.BankName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Account Number" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.AccountNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cheque Width (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeWidth, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Cheque Height (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeHeight, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Tip: set the width/height to match your real cheque, then upload a scan and position the fields visually."
                                   FontSize="11" Foreground="#888888" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Cheque template / scan -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Cheque Template" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TemplateStatus}" FontSize="12" Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Border Height="200" Background="#FAFAFA" BorderBrush="#DADADA" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12">
                            <Grid>
                                <!-- Placeholder shown when no scan -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Visibility="{Binding HasTemplate, Converter={StaticResource InverseBoolToVisibility}}">
                                    <TextBlock Text="🖼" FontSize="34" HorizontalAlignment="Center" Foreground="#BBBBBB"/>
                                    <TextBlock Text="No scanned cheque uploaded" FontSize="12" Foreground="#999999" Margin="0,6,0,0"/>
                                </StackPanel>
                                <!-- Preview when scan present -->
                                <Image Source="{Binding TemplatePreview}" Stretch="Uniform" Margin="8"
                                       Visibility="{Binding HasTemplate, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬆  Upload Scan Image" Style="{StaticResource PrimaryBtn}" Padding="14,8"
                                    Margin="0,0,8,0" Command="{Binding UploadImageCommand}"/>
                            <Button Content="✕  Remove" Style="{StaticResource SecondaryBtn}" Padding="12,7"
                                    Margin="0,0,8,0" Command="{Binding RemoveImageCommand}"/>
                            <Button Content="🎯  Design Layout (position fields)" Style="{StaticResource SecondaryBtn}" Padding="12,7"
                                    Command="{Binding DesignLayoutCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Font defaults -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Default Font" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,4"/>
                        <TextBlock Text="Used as the starting font for new fields and for the print fallback." FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Font Family" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding FontFamilies}" SelectedItem="{Binding Edit.FontFamily}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.FontSize, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Bold" Style="{StaticResource FieldLabel}"/>
                                <CheckBox IsChecked="{Binding Edit.IsBold}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status + action buttons -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" Foreground="#2E7D32" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Delete" Foreground="#8B1818" Background="Transparent" BorderThickness="1"
                                BorderBrush="#8B1818" Cursor="Hand" Padding="14,7" Margin="0,0,8,0" FontSize="13"
                                Command="{Binding DeleteCommand}"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Content="Save Profile" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
