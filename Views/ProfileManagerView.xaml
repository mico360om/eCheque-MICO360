<UserControl x:Class="eCheque.MICO360.Views.ProfileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Profile List -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Profiles" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="New" Style="{StaticResource PrimaryBtn}" Padding="12,6" FontSize="12"
                            Margin="0,0,6,0" Command="{Binding NewCommand}"/>
                    <Button Content="Duplicate" Style="{StaticResource SecondaryBtn}" Padding="10,6" FontSize="12"
                            Margin="0,0,6,0" Command="{Binding DuplicateCommand}"/>
                    <Button Content="Design Layout" Style="{StaticResource SecondaryBtn}" Padding="10,6" FontSize="12"
                            Command="{Binding DesignLayoutCommand}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding Selected}"
                         BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,3">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding BankName}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE8E8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>
        <!-- Profile Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Profile Details" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,14"/>
                    <!-- Basic Info -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Profile Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Name}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Bank Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.BankName}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Account Number" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.AccountNumber}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Cheque Width (mm)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeWidth}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Cheque Height (mm)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeHeight}"/>
                        </StackPanel>
                    </Grid>
                    <!-- Separator -->
                    <TextBlock Text="Field Positions (mm from top-left)" FontSize="13" FontWeight="SemiBold" Foreground="#555555" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Date X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.DateX}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Date Y" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.DateY}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Payee X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.PayeeX}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Payee Y" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.PayeeY}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Amount X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.AmountNumX}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Amount Y" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.AmountNumY}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Words X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.AmountWordsX}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Words Y" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.AmountWordsY}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="ChequeNo X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeNumX}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="ChequeNo Y" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeNumY}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Offset X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.PrintOffsetX}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Offset Y" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.PrintOffsetY}"/>
                        </StackPanel>
                    </Grid>
                    <!-- Font -->
                    <TextBlock Text="Font Settings" FontSize="13" FontWeight="SemiBold" Foreground="#555555" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Font Family" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding FontFamilies}"
                                      SelectedItem="{Binding Edit.FontFamily}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.FontSize}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Bold" Style="{StaticResource FieldLabel}"/>
                            <CheckBox IsChecked="{Binding Edit.IsBold}" VerticalAlignment="Center" Margin="0,6"/>
                        </StackPanel>
                    </Grid>
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Delete" Foreground="#8B1818" Background="Transparent" BorderThickness="1"
                                BorderBrush="#8B1818" Cursor="Hand" Padding="14,7" Margin="0,0,8,0" FontSize="13"
                                Command="{Binding DeleteCommand}"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Content="Save Profile" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>


