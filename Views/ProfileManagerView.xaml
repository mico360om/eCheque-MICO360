<UserControl x:Class="eCheque.MICO360.Views.ProfileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Profile list ── -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Profiles" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,10"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="＋  New Profile" Style="{StaticResource PrimaryBtn}" Padding="12,8" FontSize="12"
                            HorizontalAlignment="Stretch" Margin="0,0,0,6" Command="{Binding NewCommand}"/>
                    <Button Content="⭐  Set as Default" Style="{StaticResource SecondaryBtn}" Padding="10,7" FontSize="12"
                            HorizontalAlignment="Stretch" Margin="0,0,0,6" Command="{Binding SetDefaultCommand}"
                            ToolTip="Make the selected profile the one New Cheque pre-selects automatically."/>
                    <Button Content="⧉  Duplicate Selected" Style="{StaticResource SecondaryBtn}" Padding="10,7" FontSize="12"
                            HorizontalAlignment="Stretch" Command="{Binding DuplicateCommand}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding Selected}"
                         BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding BankName}" Foreground="#888888" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Border Grid.Column="1" VerticalAlignment="Center" Background="#E9F7EC" BorderBrush="#B7E1C1"
                                        BorderThickness="1" CornerRadius="3" Padding="5,1" Margin="6,0,0,0"
                                        Visibility="{Binding HasTemplate, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="This profile has a scanned template / saved layout">
                                    <TextBlock Text="🖼" FontSize="10"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE8E8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Editor ── -->
        <DockPanel Grid.Column="1">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E6E6E6" BorderThickness="1" CornerRadius="8" Padding="18,12" Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Profile Details" FontSize="15" FontWeight="Bold" Foreground="#8B1818"/>
                            <Border Background="#FFF6DA" BorderBrush="#E6C34D" BorderThickness="1" CornerRadius="3"
                                    Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding SelectedIsDefault, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="⭐ Default" FontSize="10.5" FontWeight="SemiBold" Foreground="#8A6D00"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Edit.Name, TargetNullValue='New profile'}" FontSize="12" Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding Edit.PaperDisplay}" VerticalAlignment="Center"
                               HorizontalAlignment="Right" FontSize="12" Foreground="#555555"/>
                </DockPanel>
            </Border>

            <!-- Sticky action bar -->
            <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E6E6E6" BorderThickness="1" CornerRadius="8" Padding="16,10" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" Foreground="#2E7D32" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="380"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Delete" Foreground="#8B1818" Background="Transparent" BorderThickness="1"
                                BorderBrush="#8B1818" Cursor="Hand" Padding="14,7" Margin="0,0,8,0" FontSize="13"
                                Command="{Binding DeleteCommand}"
                                ToolTip="Delete this profile permanently."/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Content="💾  Save Profile" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SaveCommand}"
                                ToolTip="Save changes to this profile template."/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Scrollable settings: text on the left, visual template on the right -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: all the text settings -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Bank &amp; Account" FontSize="13" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Profile Name" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.Name, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bank Name" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.BankName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Account Number" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Margin="0,0,0,14" Text="{Binding Edit.AccountNumber, UpdateSourceTrigger=PropertyChanged}"/>

                            <Border Height="1" Background="#EEEEEE" Margin="0,0,0,14"/>
                            <TextBlock Text="Cheque Size &amp; Paper" FontSize="13" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Width (mm)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeWidth, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Physical cheque width in millimetres."/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Height (mm)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.ChequeHeight, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Physical cheque height in millimetres."/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="PDF Page Size" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding PaperSizes}" SelectedItem="{Binding Edit.PaperSize}"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#EEEEEE" Margin="0,0,0,14"/>
                            <TextBlock Text="Default Font" FontSize="13" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,2"/>
                            <TextBlock Text="Starting font for new fields and the print fallback." FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Font Family" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding FontFamilies}" SelectedItem="{Binding Edit.FontFamily}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.FontSize, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Bold" Style="{StaticResource FieldLabel}"/>
                                    <CheckBox IsChecked="{Binding Edit.IsBold}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#EEEEEE" Margin="0,0,0,14"/>
                            <TextBlock Text="Print Alignment Nudge (mm)" FontSize="13" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,2"/>
                            <TextBlock Text="Shifts every printed field. To find the exact numbers, open Design Layout → 📐 Calibration Sheet, print it, and lay it over a real cheque. Positive X moves right, positive Y moves down." FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nudge X" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.PrintOffsetX, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Shift all printed fields right (+) or left (−), in mm."/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Nudge Y" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding Edit.PrintOffsetY, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Shift all printed fields down (+) or up (−), in mm."/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Right: visual template -->
                    <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Cheque Template" FontSize="13" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TemplateStatus}" FontSize="12" Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <Border Height="190" Background="#FAFAFA" BorderBrush="#DADADA" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Visibility="{Binding HasTemplate, Converter={StaticResource InverseBoolToVisibility}}">
                                        <TextBlock Text="🖼" FontSize="34" HorizontalAlignment="Center" Foreground="#BBBBBB"/>
                                        <TextBlock Text="No scanned cheque uploaded" FontSize="12" Foreground="#999999" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Image Source="{Binding TemplatePreview}" Stretch="Uniform" Margin="8"
                                           Visibility="{Binding HasTemplate, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>

                            <Button Content="⬆  Upload Scan Image" Style="{StaticResource PrimaryBtn}" Padding="14,8"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,6" Command="{Binding UploadImageCommand}"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="✕  Remove" Style="{StaticResource SecondaryBtn}" Padding="10,7" Command="{Binding RemoveImageCommand}"/>
                                <Button Grid.Column="2" Content="🎯  Design Layout" Style="{StaticResource SecondaryBtn}" Padding="10,7" Command="{Binding DesignLayoutCommand}"/>
                            </Grid>
                            <TextBlock Text="Upload your real scanned cheque, then open Design Layout to drag each field onto it. Only the data prints — the scan is a guide."
                                       FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
