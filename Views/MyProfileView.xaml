<UserControl x:Class="eCheque.MICO360.Views.MyProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="620" HorizontalAlignment="Left">

            <!-- Account details -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="My Profile" FontSize="16" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,14"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Username}" IsReadOnly="True" Background="#F8F8F8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Role" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding Role}" IsReadOnly="True" Background="#F8F8F8"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Full Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding ProfileStatus}" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#2E7D32" FontSize="12"/>
                        <Button Content="Save Profile" Style="{StaticResource PrimaryBtn}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Command="{Binding SaveProfileCommand}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Change password -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Change Password" FontSize="14" FontWeight="Bold" Foreground="#8B1818" Margin="0,0,0,12"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Current Password" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="PwdCurrent" Padding="8,6" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="New Password" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="PwdNew" Padding="8,6" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Confirm New Password" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="PwdConfirm" Padding="8,6" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Minimum 8 characters, with letters and numbers." FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                    <DockPanel>
                        <TextBlock Text="{Binding PasswordStatus}" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#8B1818" FontSize="12" TextWrapping="Wrap" MaxWidth="380"/>
                        <Button Content="Change Password" Style="{StaticResource PrimaryBtn}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Click="BtnChangePassword_Click"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
