<UserControl x:Class="eCheque.MICO360.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <UserControl.Resources>
        <!-- Stat card with left accent bar -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#E6E6E6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <!-- Quick action button -->
        <Style x:Key="QuickBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="#E6E6E6" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFE8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Row action button in DataGrid -->
        <Style x:Key="RowBtn" TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,20,20,24">

            <!-- PDC due reminder banner -->
            <Button Command="{Binding PdcCommand}" Cursor="Hand" BorderThickness="0" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch" Margin="0,0,0,14" Padding="0"
                    Visibility="{Binding HasPdcAlert, Converter={StaticResource BoolToVisibility}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#FFF4E5" BorderBrush="#FFCC80" BorderThickness="1" CornerRadius="6" Padding="14,10">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="{Binding PdcAlert}" Foreground="#B26A00" FontSize="13" FontWeight="SemiBold"/>
            </Button>

            <!-- Welcome Row -->
            <DockPanel Margin="0,0,0,16" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#1A1A1A">
                        <Run Text="Welcome back, "/>
                        <Run x:Name="RunUser" Foreground="#8B1818"/>
                    </TextBlock>
                    <TextBlock x:Name="RunCo" FontSize="12" Foreground="#888888" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="↻  Refresh" DockPanel.Dock="Right" Style="{StaticResource SecondaryBtn}"
                        Padding="14,7" Command="{Binding RefreshCommand}" VerticalAlignment="Top"
                        HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- ── Quick Actions ── -->
            <UniformGrid Columns="4" Margin="0,0,0,18" Height="80">
                <Button Style="{StaticResource QuickBtn}" Command="{Binding NewChequeCommand}" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="✚" FontSize="20" Foreground="#8B1818" HorizontalAlignment="Center"/>
                        <TextBlock Text="New Cheque" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource QuickBtn}" Command="{Binding HistoryCommand}" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="☰" FontSize="20" Foreground="#1565C0" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cheque History" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource QuickBtn}" Command="{Binding PendingCommand}" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🖨" FontSize="18" Foreground="#E65100" HorizontalAlignment="Center"/>
                        <TextBlock Text="Print Pending" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Draft, StringFormat='{}{0} awaiting'}" FontSize="10" Foreground="#E65100" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource QuickBtn}" Command="{Binding BackupCommand}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="💾" FontSize="18" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Create Backup" FontSize="12" FontWeight="SemiBold" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Backup status -->
            <TextBlock Text="{Binding BackupStatus}" FontSize="11" Foreground="#2E7D32"
                       Visibility="{Binding BackupStatus, Converter={StaticResource StringToVisibility}}"
                       Margin="0,-10,0,10" HorizontalAlignment="Right"/>

            <!-- ── Row 1: Cheque counts (3 cards) ── -->
            <UniformGrid Columns="3" Margin="0,0,0,12">

                <!-- Total Cheques -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <Grid>
                        <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#1A1A1A"/>
                        <StackPanel Margin="16,14,14,14">
                            <TextBlock Text="TOTAL CHEQUES" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Total}" FontSize="40" FontWeight="Bold" Foreground="#1A1A1A" LineHeight="44"/>
                            <TextBlock FontSize="11" Foreground="#666666" Margin="0,6,0,0">
                                <Run Text="Printed: " Foreground="#2E7D32"/><Run Text="{Binding Printed}" Foreground="#2E7D32" FontWeight="SemiBold"/>
                                <Run Text="  Draft: " Foreground="#E65100"/><Run Text="{Binding Draft}" Foreground="#E65100" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="#666666" Margin="0,2,0,0">
                                <Run Text="Cancelled: " Foreground="#C62828"/><Run Text="{Binding Cancelled}" Foreground="#C62828" FontWeight="SemiBold"/>
                                <Run Text="  Voided: " Foreground="#888888"/><Run Text="{Binding Voided}" Foreground="#888888" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Printed -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <Grid>
                        <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#2E7D32"/>
                        <StackPanel Margin="16,14,14,14">
                            <TextBlock Text="PRINTED" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Printed}" FontSize="40" FontWeight="Bold" Foreground="#2E7D32" LineHeight="44"/>
                            <TextBlock FontSize="11" Foreground="#666666" Margin="0,6,0,0">
                                <Run Text="Today: "/><Run Text="{Binding TodayPrinted}" FontWeight="Bold" Foreground="#1A1A1A"/>
                                <Run Text="  This Month: "/><Run Text="{Binding MonthPrinted}" FontWeight="Bold" Foreground="#1A1A1A"/>
                            </TextBlock>
                            <TextBlock Text="Successfully printed cheques" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Pending / Draft — clickable -->
                <Border Style="{StaticResource StatCard}" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding PendingCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#E65100"/>
                        <StackPanel Margin="16,14,14,14">
                            <TextBlock Text="PENDING / DRAFT" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Draft}" FontSize="40" FontWeight="Bold" Foreground="#E65100" LineHeight="44"/>
                            <TextBlock FontSize="11" Foreground="#888888" Margin="0,6,0,0">
                                <Run Text="Awaiting print — "/>
                                <Run Text="click to view" Foreground="#E65100" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Text="Includes Draft and ReadyToPrint" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- ── Row 2: Value cards (3 cards) ── -->
            <UniformGrid Columns="3" Margin="0,0,0,18">

                <!-- Monthly Value -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <Grid>
                        <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#1565C0"/>
                        <StackPanel Margin="16,14,14,14">
                            <TextBlock Text="THIS MONTH ISSUED" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="#1565C0" LineHeight="28">
                                <Run Text="{Binding Currency}"/><Run Text=" "/><Run Text="{Binding MonthAmount, StringFormat=N3}"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="#888888" Margin="0,6,0,0">
                                <Run Text="{Binding MonthPrinted}"/><Run Text=" cheques printed this month"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Yearly Value -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <Grid>
                        <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#6A1B9A"/>
                        <StackPanel Margin="16,14,14,14">
                            <TextBlock Text="THIS YEAR ISSUED" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="#6A1B9A" LineHeight="28">
                                <Run Text="{Binding Currency}"/><Run Text=" "/><Run Text="{Binding YearAmount, StringFormat=N3}"/>
                            </TextBlock>
                            <TextBlock Text="Year-to-date printed value" FontSize="11" Foreground="#AAAAAA" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Total Issued All Time -->
                <Border Style="{StaticResource StatCard}">
                    <Grid>
                        <Border Width="5" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#8B1818"/>
                        <StackPanel Margin="16,14,14,14">
                            <TextBlock Text="TOTAL ISSUED (ALL TIME)" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="#8B1818" LineHeight="28">
                                <Run Text="{Binding Currency}"/><Run Text=" "/><Run Text="{Binding TotalAmount, StringFormat=N3}"/>
                            </TextBlock>
                            <TextBlock Text="Cumulative value of printed cheques" FontSize="11" Foreground="#AAAAAA" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- ── Recent Cheques ── -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <!-- Header -->
                    <Border Padding="16,12" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="Recent Cheques" FontSize="14" FontWeight="Bold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            <Button Content="View All →" DockPanel.Dock="Right" Style="{StaticResource SecondaryBtn}"
                                    Padding="12,5" FontSize="12" Command="{Binding HistoryCommand}"/>
                        </DockPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding Recent}" MaxHeight="360"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F5F5F5" BorderThickness="0"
                              RowBackground="White" AlternatingRowBackground="#FDFAFA"
                              SelectionMode="Single" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cheque #"  Binding="{Binding ChequeNumber}"                   Width="95"/>
                            <DataGridTextColumn Header="Date"      Binding="{Binding ChequeDate, StringFormat=dd/MM/yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Payee"     Binding="{Binding PayeeName}"                       Width="*"/>
                            <DataGridTextColumn Header="Bank"      Binding="{Binding BankName}"                        Width="130"/>
                            <DataGridTextColumn Header="Amount"    Binding="{Binding Amount, StringFormat=N3}"         Width="100"/>
                            <DataGridTextColumn Header="Status"    Binding="{Binding Status}"                          Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="Printed">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Reprinted">
                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Draft">
                                                <Setter Property="Foreground" Value="#E65100"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Cancelled">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <!-- Actions column -->
                            <DataGridTemplateColumn Header="Actions" Width="145">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4,2">
                                            <Button Content="Print"
                                                    Style="{StaticResource RowBtn}"
                                                    Background="#8B1818" Foreground="White" BorderBrush="#8B1818"
                                                    Margin="0,0,5,0"
                                                    Command="{Binding DataContext.PrintRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="View"
                                                    Style="{StaticResource RowBtn}"
                                                    Background="Transparent" Foreground="#1565C0" BorderBrush="#1565C0"
                                                    Command="{Binding DataContext.ViewRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
