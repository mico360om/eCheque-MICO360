<Window x:Class="eCheque.MICO360.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview — eCheque MICO360"
        Width="820" Height="640"
        WindowStartupLocation="CenterOwner"
        Icon="/logo.ico"
        Background="#F5F5F5"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <TextBlock Text="Cheque Print Preview" FontSize="16" FontWeight="Bold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnPrint" Content="Print Now" Style="{StaticResource PrimaryBtn}"
                            Margin="0,0,8,0" Click="BtnPrint_Click"/>
                    <Button x:Name="BtnTestPrint" Content="Test on Plain Paper" Style="{StaticResource SecondaryBtn}"
                            ToolTip="Prints the alignment grid (rulers + field markers) on plain paper — hold it against a real cheque leaf to verify positions before using a cheque."
                            Margin="0,0,8,0" Click="BtnTestPrint_Click"/>
                    <Button x:Name="BtnChoosePrinter" Content="Printer…" Style="{StaticResource SecondaryBtn}"
                            ToolTip="Choose and remember the cheque printer for this PC."
                            Margin="0,0,8,0" Click="BtnChoosePrinter_Click"/>
                    <Button x:Name="BtnSavePdf" Content="Save PDF" Style="{StaticResource SecondaryBtn}"
                            Margin="0,0,8,0" Click="BtnSavePdf_Click"/>
                    <Button Content="Close" Style="{StaticResource SecondaryBtn}" Click="BtnClose_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- Preview Area — the whole cheque always scales to fit the window (never cut off). -->
        <Border Grid.Row="1" Background="#888888">
            <Viewbox Stretch="Uniform" StretchDirection="Both" Margin="24">
                <Border Background="White" BorderBrush="#BBBBBB" BorderThickness="1">
                    <Image x:Name="PreviewImage" Stretch="None"/>
                </Border>
            </Viewbox>
        </Border>
        <!-- Info bar: cheque info + paper-size check + app version -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16,8">
            <DockPanel>
                <TextBlock x:Name="TxtVersion" DockPanel.Dock="Right" Foreground="#BBBBBB" FontSize="11"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           ToolTip="Installed application version — if a fix seems missing, check this matches the latest release."/>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtInfo" Foreground="#666666" FontSize="12"/>
                        <TextBlock x:Name="TxtPdfPath" Foreground="#8B1818" FontSize="12" Margin="16,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtPaperCheck" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
