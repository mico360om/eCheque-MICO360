<UserControl x:Class="eCheque.MICO360.Views.BatchPrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Cheque Profile / Account" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputCombo}" ItemsSource="{Binding Profiles}"
                                  ToolTip="Account profile used for every cheque in this batch."
                                  SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Start Number (optional override)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding StartNumberOverride, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="First cheque number — leave blank to continue from the profile's last number."/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="⭱  Import File" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"
                                ToolTip="Import an Excel or CSV list of payees and amounts."
                                Command="{Binding ImportCommand}" IsEnabled="{Binding CanEdit}"/>
                        <Button Content="Re-number" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Command="{Binding AssignCommand}"
                                ToolTip="Re-assign sequential cheque numbers to every row."/>
                        <Button Content="Validate" Style="{StaticResource SecondaryBtn}" Command="{Binding ValidateCommand}"
                                ToolTip="Check every row for errors before printing."/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding ProfileInfo}" Foreground="#8B1818" FontSize="12" Margin="0,8,0,0"/>
                <TextBlock Text="Expected columns: Payee, Amount, and optionally Cheque Number, Date, Reference, Invoice, Memo. The first row may be a header."
                           Foreground="#AAAAAA" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Preview grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" BorderThickness="0"
                          CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNo}" IsReadOnly="True" Width="40"/>
                        <DataGridTextColumn Header="Cheque #" Binding="{Binding ChequeNumber}" Width="110"/>
                        <DataGridTextColumn Header="Payee" Binding="{Binding PayeeName}" Width="*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N3}" Width="110"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding ChequeDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="110"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel}" IsReadOnly="True" Width="200">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                            <Setter Property="Foreground" Value="#B00020"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsValid}" Value="True">
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="🖨" FontSize="34" HorizontalAlignment="Center" Foreground="#CCCCCC"/>
                    <TextBlock Text="No batch loaded" FontSize="14" FontWeight="SemiBold" Foreground="#888888" HorizontalAlignment="Center" Margin="0,8,0,2"/>
                    <TextBlock Text="Import an Excel or CSV list of payees and amounts to begin." FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="Save as Drafts" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                        ToolTip="Save all rows as drafts without printing."
                        Command="{Binding SaveDraftsCommand}" IsEnabled="{Binding CanEdit}"/>
                <Button Content="🖨  Print All" Style="{StaticResource PrimaryBtn}"
                        ToolTip="Print every valid cheque — uses one physical leaf per cheque."
                        Command="{Binding PrintAllCommand}" IsEnabled="{Binding CanEdit}"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="{Binding Summary}" Foreground="#8B1818" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
