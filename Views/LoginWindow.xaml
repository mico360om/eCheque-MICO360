<Window x:Class="eCheque.MICO360.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:eCheque.MICO360.ViewModels"
        Title="eCheque MICO360 — Login"
        Width="820" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI"
        Icon="/logo.png">
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.45"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL — Brand -->
            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="12,0,0,12">
                <!-- Subtle red accent strip on right edge -->
                <Border BorderBrush="#8B1818" BorderThickness="0,0,3,0">
                    <Grid>
                        <!-- Drag handle -->
                        <Grid.Background>
                            <SolidColorBrush Color="#1A1A1A"/>
                        </Grid.Background>
                        <Grid MouseLeftButtonDown="TitleBar_MouseDown" Background="Transparent" VerticalAlignment="Top" Height="40"/>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Source="/logo-w.png" MaxWidth="200" MaxHeight="72"
                                   Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,20"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="eCheque MICO360" FontSize="18" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Cheque Printing System" FontSize="12"
                                       Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                            <!-- Decorative divider -->
                            <Rectangle Height="2" Width="60" Fill="#8B1818" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                            <TextBlock Text="Secure · Multi-Company" FontSize="11"
                                       Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Professional Cheque Management" FontSize="11"
                                       Foreground="#555555" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Version at bottom -->
                        <TextBlock Text="v2.0" FontSize="10" Foreground="#3A3A3A"
                                   VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    </Grid>
                </Border>
            </Border>

            <!-- RIGHT PANEL — Form -->
            <Border Grid.Column="1" Background="White" CornerRadius="0,12,12,0">
                <Grid>
                    <!-- Close button -->
                    <Button Content="✕" Click="BtnClose_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,14,0" Width="28" Height="28"
                            FontSize="13" Background="Transparent" BorderThickness="0"
                            Foreground="#AAAAAA" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFEEEE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Form -->
                    <StackPanel VerticalAlignment="Center" Margin="44,0,44,0">
                        <TextBlock Text="Welcome Back" FontSize="24" FontWeight="Bold"
                                   Foreground="#1A1A1A" Margin="0,0,0,4"/>
                        <TextBlock Text="Sign in to your account" FontSize="13"
                                   Foreground="#888888" Margin="0,0,0,28"/>

                        <!-- ============ PASSWORD LOGIN ============ -->
                        <StackPanel Visibility="{Binding PasswordMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="USERNAME" FontSize="10" FontWeight="Bold"
                                       Foreground="#888888" Margin="0,0,0,5"/>
                            <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5"
                                    Background="White" x:Name="UsernameBorder" Margin="0,0,0,14">
                                <TextBox x:Name="TxtUsername"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" FontSize="14" FontFamily="Segoe UI"
                                         Background="White" Foreground="#1A1A1A" CaretBrush="#1A1A1A"
                                         BorderThickness="0" Height="40"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="Bold"
                                       Foreground="#888888" Margin="0,0,0,5"/>
                            <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5"
                                    Background="White" x:Name="PasswordBorder" Margin="0,0,0,14">
                                <PasswordBox x:Name="TxtPassword"
                                             Padding="10,8" FontSize="14" FontFamily="Segoe UI"
                                             Background="White" Foreground="#1A1A1A" CaretBrush="#1A1A1A"
                                             BorderThickness="0" Height="40"
                                             VerticalContentAlignment="Center"/>
                            </Border>

                            <Button Content="SIGN IN" Height="42" FontSize="13" FontWeight="Bold"
                                    Style="{StaticResource PrimaryBtn}" Click="LoginBtn_Click" Margin="0,0,0,10"/>
                            <TextBlock HorizontalAlignment="Center" FontSize="12">
                                <Hyperlink Command="{Binding UseOtpCommand}" Foreground="#8B1818"
                                           TextDecorations="None"><Run Text="Sign in with Email OTP"/></Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- ============ EMAIL OTP LOGIN ============ -->
                        <StackPanel Visibility="{Binding OtpMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="EMAIL" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,5"/>
                            <TextBox Style="{StaticResource InputBox}" Height="40" FontSize="14" CaretBrush="#1A1A1A"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <Button Content="SEND CODE" Height="40" FontSize="13" FontWeight="Bold"
                                    Style="{StaticResource PrimaryBtn}" Command="{Binding SendOtpCommand}" Margin="0,0,0,12"/>

                            <StackPanel Visibility="{Binding OtpSent, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="ENTER CODE" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,5"/>
                                <TextBox Style="{StaticResource InputBox}" Height="40" FontSize="18" FontWeight="Bold"
                                         CaretBrush="#1A1A1A" Text="{Binding OtpCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                <Button Content="VERIFY &amp; SIGN IN" Height="42" FontSize="13" FontWeight="Bold"
                                        Style="{StaticResource PrimaryBtn}" Command="{Binding VerifyOtpCommand}" Margin="0,0,0,10"/>
                            </StackPanel>

                            <TextBlock HorizontalAlignment="Center" FontSize="12">
                                <Hyperlink Command="{Binding UsePasswordCommand}" Foreground="#8B1818"
                                           TextDecorations="None"><Run Text="Use username &amp; password"/></Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Status + Error (shared) -->
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC2020"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>

                        <!-- Security notice -->
                        <TextBlock Text="Authorized users only" FontSize="11"
                                   Foreground="#BBBBBB" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
