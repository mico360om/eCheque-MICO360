<Window x:Class="eCheque.MICO360.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="eCheque MICO360"
        Width="1280" Height="800" MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Icon="/logo.ico"
        Background="#F5F5F5"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1A1A1A">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="16,18,16,14" BorderBrush="#2C2C2C" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Image Source="/logo-w.png" Height="48" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="eCheque MICO360" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtCompanyName" FontSize="11" Foreground="#8B1818" FontWeight="SemiBold" Margin="0,1,0,0"/>
                        <TextBlock x:Name="TxtUserInfo" FontSize="11" Foreground="#777777"/>
                    </StackPanel>
                </Border>
                <!-- Logout -->
                <Border DockPanel.Dock="Bottom" Padding="10,8" BorderBrush="#2C2C2C" BorderThickness="0,1,0,0">
                    <Button x:Name="BtnLogout" Content="  Logout" Foreground="#777777" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" FontSize="13" HorizontalAlignment="Left"
                            Click="BtnLogout_Click" Style="{StaticResource NavBtn}"
                            ToolTip="End your session on this PC."/>
                </Border>
                <!-- Server connection status (click to open Sync settings) -->
                <Border x:Name="SyncStatusBar" DockPanel.Dock="Bottom" Padding="14,8" Cursor="Hand"
                        Background="Transparent" BorderBrush="#2C2C2C" BorderThickness="0,1,0,0"
                        MouseLeftButtonUp="SyncStatus_Click" ToolTip="Cloud sync status — click for settings">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="SyncDot" Width="9" Height="9" Fill="#888888" VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="SyncStatusText" Text="Local only" Foreground="#BBBBBB" FontSize="12"/>
                            <TextBlock x:Name="SyncStatusSub" Text="cloud sync off" Foreground="#6E6E6E" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- Nav -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                    <ScrollViewer.Resources>
                        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4A4A4A"/>
                        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#7A7A7A"/>
                    </ScrollViewer.Resources>
                    <StackPanel Margin="8,8">
                        <TextBlock Text="MAIN" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,6,0,4"/>
                        <Button x:Name="NavDashboard"    Tag="Dashboard"    Content="🏠  Dashboard"       Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavNewCheque"   Tag="NewCheque"    Content="✚  New Cheque"       Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavHistory"     Tag="History"      Content="☰  Cheque History"   Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavTracking"    Tag="Tracking"     Content="📅  Cheque Tracking"  Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                ToolTip="PDC register &amp; reconciliation for post-dated cheques."/>
                        <Button x:Name="NavBatch"       Tag="Batch"        Content="🗇  Batch Print"     Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                ToolTip="Print many cheques from an Excel/CSV list."/>
                        <Button x:Name="NavChequeBooks" Tag="ChequeBooks"  Content="📘  Cheque Books"    Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                ToolTip="Track leaf inventory &amp; prevent duplicate cheque numbers."/>
                        <Button x:Name="NavPrintHistory" Tag="PrintHistory" Content="🖨  Print History"   Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                ToolTip="Log of every print and reprint job."/>
                        <TextBlock Text="CONFIGURATION" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,14,0,4"/>
                        <Button x:Name="NavProfiles"  Tag="Profiles"  Content="📄  Cheque Profiles"  Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                ToolTip="Manage cheque print templates — bank, size &amp; field positions."/>
                        <Button x:Name="NavMyProfile" Tag="MyProfile" Content="👤  My Profile"       Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavSettings"  Tag="Settings"  Content="⚙  Settings"         Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <TextBlock x:Name="TxtAdminHdr" Text="ADMINISTRATION" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,14,0,4"/>
                        <Button x:Name="NavCompanies" Tag="Companies" Content="🏢  Companies"        Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavUsers"     Tag="Users"     Content="👤  Users"            Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavAudit"     Tag="Audit"     Content="📋  Audit Log"        Style="{StaticResource NavBtn}" Click="NavBtn_Click"
                                ToolTip="Record of every action taken in the app."/>
                        <TextBlock Text="HELP &amp; LEGAL" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="8,14,0,4"/>
                        <Button x:Name="NavUpdates"  Tag="Updates"  Content="🔄  Check for Updates"  Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavTerms"    Tag="Terms"    Content="📜  Terms &amp; Conditions" Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavPrivacy"  Tag="Privacy"  Content="🔒  Privacy Policy"     Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                        <Button x:Name="NavAbout"    Tag="About"    Content="ℹ  About Us"            Style="{StaticResource NavBtn}" Click="NavBtn_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
        <!-- CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="24,10">
                <DockPanel>
                    <TextBlock x:Name="TxtPageTitle" Text="Dashboard" FontSize="20" FontWeight="Bold"
                               Foreground="#1A1A1A" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Global cheque search (Ctrl+F): number, payee or bank — Enter opens History filtered. -->
                        <Border Background="#F7F7F7" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4"
                                Padding="8,0" Margin="0,0,14,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Foreground="#999999" Margin="0,0,6,0"/>
                                <TextBox x:Name="TxtGlobalSearch" Width="190" BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" FontSize="12" Padding="0,6"
                                         KeyDown="GlobalSearch_KeyDown"
                                         ToolTip="Search cheque #, payee or bank across all cheques (Ctrl+F). Press Enter."/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="🏢" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CmbCompanySwitch" MinWidth="180" Style="{StaticResource InputCombo}"
                                  SelectionChanged="CmbCompanySwitch_SelectionChanged" ToolTip="Switch active company">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock x:Name="TxtDateTime" FontSize="12" Foreground="#888888"
                                   VerticalAlignment="Center" Margin="18,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <ContentControl x:Name="MainContent" Grid.Row="1"/>
        </Grid>
        <!-- Toast / snackbar host (top-right of the content area) -->
        <StackPanel x:Name="ToastHostPanel" Grid.Column="1" Panel.ZIndex="900"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,64,20,0" Width="380"/>

        <!-- Session Lock Overlay -->
        <Grid x:Name="LockOverlay" Grid.ColumnSpan="2" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="999">
            <Border Background="White" CornerRadius="10" Padding="36,28" Width="360" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <Image Source="/logo.png" Height="48" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Session Locked" FontSize="20" FontWeight="Bold" Foreground="#8B1818" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter your password to continue" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <PasswordBox x:Name="PwdUnlock" Padding="10,8" FontSize="14" Margin="0,0,0,12"
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>
                    <TextBlock x:Name="TxtUnlockError" Foreground="#CC0000" FontSize="12" Margin="0,0,0,10" Visibility="Collapsed"/>
                    <Button Content="Unlock" Style="{StaticResource PrimaryBtn}" Click="BtnUnlock_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
